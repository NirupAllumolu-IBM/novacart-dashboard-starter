# ── Data backend ─────────────────────────────────────────────────────────────
# 'sqlite'    = use local SQLite file (default for local development)
# 'snowflake' = use Snowflake (used in SPCS deployment)
DATA_BACKEND=sqlite

# ── SQLite (local development only) ──────────────────────────────────────────
SQLITE_PATH=../data/novacart_gold.db

# ── Snowflake (fill in when using Snowflake) ──────────────────────────────────
# Find your account identifier: SELECT CURRENT_ACCOUNT(), CURRENT_REGION();
# Format: <locator>.<region>  e.g. ABC12345.us-east-1
SNOWFLAKE_ACCOUNT=VEB81086.aws_us_east_1

# Find your exact username: SELECT CURRENT_USER();
SNOWFLAKE_USERNAME=NOVACART_TEAM1

SNOWFLAKE_ROLE=NOVACART_EXT_ROLE
SNOWFLAKE_WAREHOUSE=NOVACART_APP_WH
SNOWFLAKE_DATABASE=NOVACART_DB
SNOWFLAKE_SCHEMA=APP

# Keypair authentication (required if your account enforces MFA)
# Generate: openssl genrsa 2048 | openssl pkcs8 -topk8 -inform PEM -out rsa_key.p8 -nocrypt
SNOWFLAKE_PRIVATE_KEY_PATH=/Users/arjunshokeen/.snowflake/keys/rsa_key.p8

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000